meta {
  name: Sign In
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/auth/sign-in
  body: json
  auth: none
}

body:json {
  {
    "nickname": "testuser",
    "password": "password123"
  }
}

script:post-response {
  if (res.body.accessToken) {
    bru.setVar("accessToken", res.body.accessToken);
  }
}
