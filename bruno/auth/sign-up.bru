meta {
  name: Sign Up
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/sign-up
  body: json
  auth: none
}

body:json {
  {
    "nickname": "testuser",
    "email": "test@example.com",
    "password": "Password123!"
  }
}

script:post-response {
  if (res.body.accessToken) {
    bru.setVar("accessToken", res.body.accessToken);
  }
}
